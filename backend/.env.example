# Delta backend secrets — copy to backend/.env and fill in.
# backend/.env is loaded automatically at startup; never commit it.

# Anthropic API key (https://platform.claude.com/settings/keys)
# With a key set, the overview / news summary / scenarios / analyst chat
# endpoints are generated live by Claude; without it they use cached fallbacks.
ANTHROPIC_API_KEY=

# SAHMK (sahmk.sa) — Tadawul-licensed quote API, free tier.
# Used ONLY for display-only live quotes / market summary (backend/app/live.py).
# Never consumed by valuation, baseline, or anomaly calculations.
SAHMK_API_KEY=
